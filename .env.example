# Copy to .env and fill in — never commit .env

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Railway (for deployments)
RAILWAY_TOKEN=...

# Tavily (research agent web search)
TAVILY_API_KEY=tvly-...

# Paths
MEDIA_DRIVE=D:/media          # external drive for video
SQLITE_PATH=./memory/sqlite/mission_control.db
LANCEDB_PATH=./memory/lancedb
